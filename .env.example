# API key de Resend (https://resend.com). Si está vacío, Pidgeon simula envíos en consola (solo desarrollo).
RESEND_API_KEY=

# Dominio para el remitente por defecto: noreply@${DOMAIN}
DOMAIN=turnosok.com

# Puerto local (Render inyecta PORT automáticamente)
PORT=3000

# Opcional: URL pública del servicio para el keep-alive (Render define RENDER_EXTERNAL_URL solo en producción).
# PUBLIC_URL=https://tu-servicio.onrender.com
